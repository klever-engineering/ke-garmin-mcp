# Garmin Connect credentials (required for first login and token refresh fallback)
GARMIN_USERNAME=your_garmin_username
GARMIN_PASSWORD=your_garmin_password

# Optional: project-local token directory (relative path recommended)
GARMIN_TOKENS_DIR=.state/garmin-tokens

# Optional: max date range accepted by range-based CLI/MCP tools
GARMIN_MAX_RANGE_DAYS=93

# Optional: explicit env file path (use env var when absolute path is needed)
# GARMIN_ENV_FILE=/path/to/.env

